// Z-GRC — EN 18031 self-assessment data model

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String // "customer" | "consultant"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects            Project[]
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256 of the raw token (we never store the raw)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Project {
  id                 String   @id @default(cuid())
  name               String
  manufacturer       String
  contactName        String?
  contactEmail       String?
  productType        String?
  productDescription String?
  standard           String? // "RED" | "FDA"

  // Owner (customer who created it). Null for legacy projects — visible to
  // consultants but not to any customer.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Applicability results computed from screening
  applicable1 Boolean @default(false) // EN 18031-1
  applicable2 Boolean @default(false) // EN 18031-2
  applicable3 Boolean @default(false) // EN 18031-3

  // Mechanism candidates as JSON array of codes, e.g. ["ACM","AUM","SUM",...]
  mechanismCandidates String @default("[]")

  screeningComplete Boolean @default(false)

  // Collaboration workflow stage. Drives whose turn it is (customer vs
  // consultant) and which AI fill runs next. Values (see src/lib/workflow.ts):
  //   INTAKE → ASSETS_RUNNING → ASSETS_CUSTOMER → ASSETS_CONSULTANT →
  //   DT_RUNNING → DT_CUSTOMER → DT_CONSULTANT →
  //   ASSESSMENT_RUNNING → ASSESSMENT → REPORT_CUSTOMER → DONE
  phase          String   @default("INTAKE")
  phaseUpdatedAt DateTime @default(now())

  // When a customer rejects an AI stage, their reason is stored here and fed
  // into the next AI re-run prompt ("보완해서 다시 만들어라"); cleared once consumed.
  aiFeedbackNote String   @default("")

  // Finalization — once finalized, mutations are locked. Set back to null to unlock.
  finalizedAt   DateTime?
  finalizedBy   String?
  finalizedNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  screeningAnswers ScreeningAnswer[]
  assets           Asset[]
  dtAnswers        DTAnswer[]
  dtEvidences      DTEvidence[]
  dtAssessments    DTAssessment[]
  attachments      ProjectAttachment[]
  shareTokens      ShareToken[]
  firmwareAnalyses FirmwareAnalysis[]
  aiPipelineRuns   AiPipelineRun[]
  dtRemediations   DTRemediation[]
  notifications    Notification[]
}

// Result of the one-time heavy firmware analysis (binwalk extraction + agentic
// inspection). Downstream AI steps (asset id, DT, evidence, assessment) reuse
// `findings` instead of re-reading the firmware; the agent may drill down
// further into the retained extracted rootfs and append to findings.
model FirmwareAnalysis {
  id           String    @id @default(cuid())
  projectId    String
  attachmentId String? // the firmware ProjectAttachment analyzed
  status       String    @default("pending") // pending|extracting|analyzing|done|failed
  findings     String    @default("") // structured findings JSON
  extractedPath String? // server-side path to extracted rootfs (for drill-down)
  error        String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Tracks one "AI 전체 자동 수행" background run so the UI can show progress.
// Steps run in dependency order: firmware → assets → dt → evidence → assessment.
model AiPipelineRun {
  id         String    @id @default(cuid())
  projectId  String
  stage      String    @default("full") // full|assets|dt|assessment — which flow segment this run covers
  status     String    @default("queued") // queued|running|done|failed|canceled
  step       String    @default("") // firmware|assets|dt|evidence|assessment
  total      Int       @default(0) // total work units for the current step
  completed  Int       @default(0) // completed units for the current step
  message    String    @default("") // human-readable progress line
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Read-only share links — any holder of the URL can view the project in read-only mode.
model ShareToken {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  token     String    @unique // random 32-char hex
  label     String    @default("")
  createdBy String? // userId of creator
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([projectId])
}

model ScreeningAnswer {
  id         String   @id @default(cuid())
  projectId  String
  questionId String // e.g., "A1", "B3"
  answer     String // "yes" | "no"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  aiGenerated    Boolean   @default(false)
  aiGeneratedAt  DateTime?
  userReviewed   Boolean   @default(false)
  userReviewedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, questionId])
}

model Asset {
  id          String  @id @default(cuid())
  projectId   String
  kind        String // "network_interface" | "network_service" | "data_flow" | "security_asset" | "function"
  name        String
  description String?
  metadata    String  @default("{}") // JSON

  aiGenerated    Boolean   @default(false)
  aiGeneratedAt  DateTime?
  userReviewed   Boolean   @default(false)
  userReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dtAnswers      DTAnswer[]
  dtEvidences    DTEvidence[]
  dtAssessments  DTAssessment[]
  dtRemediations DTRemediation[]
}

model DTAnswer {
  id            String  @id @default(cuid())
  projectId     String
  assetId       String? // null for global-scope (non-per-asset) requirements
  mechanismCode String // "ACM", "AUM", "SUM", ...
  requirementId String // "ACM-1", "AUM-1", ...
  nodeId        String // "DN-1", "DN-2", ...
  answer        String // "yes" | "no"
  notes         String?

  aiGenerated    Boolean   @default(false)
  aiGeneratedAt  DateTime?
  userReviewed   Boolean   @default(false)
  userReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([projectId, assetId, requirementId, nodeId])
}

// Structured required-information evidence per EN 18031 spec.
// Each requirement may declare an evidenceFields schema; users fill the
// values which are keyed by (project, asset, requirement, fieldId).
model DTEvidence {
  id            String  @id @default(cuid())
  projectId     String
  assetId       String? // null for requirement-level (non per-asset) fields
  requirementId String // e.g. "P1.ACM-1"
  fieldId       String // e.g. "E.Info.ACM-1.SecurityAsset.Access"
  value         String  @default("")

  attachmentFilename   String?
  attachmentStoredPath String?
  attachmentMimeType   String?
  attachmentSize       Int?

  aiGenerated    Boolean   @default(false)
  aiGeneratedAt  DateTime?
  userReviewed   Boolean   @default(false)
  userReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([projectId, assetId, requirementId, fieldId])
}

// Technical assessment recorded by a certification consultant per requirement
// (and per asset iteration). Each record captures one type of assessment for
// one (project, asset, requirement) tuple — "completeness", "sufficiency",
// or "conceptual_completeness".
model DTAssessment {
  id             String  @id @default(cuid())
  projectId      String
  assetId        String? // null for global-scope (non per-asset) requirements
  requirementId  String // e.g. "P1.ACM-1"
  assessmentType String // "completeness" | "sufficiency" | "conceptual_completeness"
  testMethod     String  @default("")
  testResult     String  @default("")
  verdict        String? // "pass" | "fail" | "not_applicable"

  // Optional evidence attachment (one file per assessment for now).
  attachmentFilename   String?
  attachmentStoredPath String?
  attachmentMimeType   String?
  attachmentSize       Int?

  aiGenerated    Boolean   @default(false)
  aiGeneratedAt  DateTime?
  userReviewed   Boolean   @default(false)
  userReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([projectId, assetId, requirementId, assessmentType])
}

// Uploaded product documentation — manuals, architecture diagrams, specifications,
// certificates, etc. Files are stored on local disk under uploads/{projectId}/…,
// with metadata recorded here.
model ProjectAttachment {
  id          String @id @default(cuid())
  projectId   String
  kind        String @default("document") // "document" | "firmware"
  filename    String // original filename (as submitted by user)
  storedPath  String // relative path from uploads/ (e.g. "{projectId}/{uuid}-manual.pdf")
  mimeType    String
  size        Int
  description String @default("")

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Remediation guidance for a DT requirement that evaluated to FAIL, plus the
// customer's response on whether the corrective action was taken. One row per
// (project, asset, requirement). `remediationText` is AI-authored (Korean);
// `actionStatus`/`customerNote` are filled by the customer during their DT
// confirmation step.
model DTRemediation {
  id            String  @id @default(cuid())
  projectId     String
  assetId       String? // null for global-scope (non per-asset) requirements
  requirementId String

  remediationText String    @default("") // AI 조치 방안 (한국어)
  aiGenerated     Boolean   @default(false)
  aiGeneratedAt   DateTime?

  // Customer response.
  actionStatus String    @default("pending") // "pending" | "done" | "in_progress" | "not_done"
  customerNote String    @default("")
  respondedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([projectId, assetId, requirementId])
}

// In-app notification. Fanned out to one row per recipient user (so unread
// state is per-user even for "all consultants" events). `type` identifies the
// workflow event; `linkPath` is where clicking the notification navigates.
model Notification {
  id              String    @id @default(cuid())
  projectId       String
  recipientUserId String
  type            String // "ASSETS_READY" | "ASSETS_CUSTOMER_CONFIRMED" | ...
  title           String
  body            String    @default("")
  linkPath        String?
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recipient User    @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, readAt])
  @@index([projectId])
}
